---
// Services.astro
---
<section id="services" class="services-section">
  <div class="services-container">
    <div class="section-header">
      <div class="section-label">
        <span class="label-number">01 //</span>
        <span class="label-text">OPERATIONAL PROTOCOLS</span>
      </div>
      <h2 class="section-title">Core Capabilities</h2>
      <p class="section-subtitle">
        We deliver enterprise-grade performance and security solutions designed for modern technical infrastructures.
      </p>
    </div>

    <div class="services-grid">
      <!-- Service Card 1 -->
      <div class="service-card">
        <div class="card-glow"></div>
        <div class="card-border"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="service-icon">
              <!-- Custom Web Engineering SVG Icon -->
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6"></polyline>
                <polyline points="8 6 2 12 8 18"></polyline>
                <line x1="14" y1="4" x2="10" y2="20"></line>
              </svg>
            </div>
            <span class="service-protocol">[ PROTOCOL-01 // DEV ]</span>
          </div>

          <h3 class="service-name">Web Engineering</h3>
          <p class="service-desc">
            Performance-first, SEO-maximized web systems built on modern frameworks. We deliver lightning-fast response times, scalable architecture, and pixel-perfect design.
          </p>

          <ul class="service-features">
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Custom Astro & React Engineering
            </li>
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Headless CMS & API Integrations
            </li>
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Lighthouse 100% Score Optimization
            </li>
          </ul>
        </div>
      </div>

      <!-- Service Card 2 -->
      <div class="service-card active">
        <div class="card-glow"></div>
        <div class="card-border"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="service-icon">
              <!-- Custom Security Audit SVG Icon -->
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            </div>
            <span class="service-protocol">[ PROTOCOL-02 // AUDIT ]</span>
          </div>

          <h3 class="service-name">Security Audits</h3>
          <p class="service-desc">
            Deep technical investigations of your networks, software stacks, and cloud environments. We expose hidden vulnerabilities before threat actors can exploit them.
          </p>

          <ul class="service-features">
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Cloud & Network Vulnerability Scans
            </li>
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Secure Code Review (Sast/Dast)
            </li>
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Compliance Gap Analysis (SOC2/GDPR)
            </li>
          </ul>
        </div>
      </div>

      <!-- Service Card 3 -->
      <div class="service-card">
        <div class="card-glow"></div>
        <div class="card-border"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="service-icon">
              <!-- Custom Pen Testing SVG Icon -->
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                <polyline points="2 17 12 22 22 17"></polyline>
                <polyline points="2 12 12 17 22 12"></polyline>
              </svg>
            </div>
            <span class="service-protocol">[ PROTOCOL-03 // DEFENSE ]</span>
          </div>

          <h3 class="service-name">Penetration Testing</h3>
          <p class="service-desc">
            Simulated offensive cyber campaigns targeting your systems. We validate your security posture using the exact Tactics, Techniques, and Procedures (TTPs) of real-world adversaries.
          </p>

          <ul class="service-features">
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Black-Box & Gray-Box Pentesting
            </li>
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Social Engineering Simulations
            </li>
            <li>
              <svg class="feat-check" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Mitigation Reports & Re-Testing
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    position: relative;
    padding: 6rem 2rem;
    background-color: var(--bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  .services-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 4rem;
    max-width: 650px;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .label-number {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-green);
  }

  .label-text {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .section-subtitle {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Grid configuration */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  /* Glassmorphic cards */
  .service-card {
    position: relative;
    background: rgba(24, 28, 40, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Highlight specific/center card */
  .service-card.active {
    background: rgba(24, 28, 40, 0.65);
    border-color: rgba(163, 230, 53, 0.25);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at top right, rgba(163, 230, 53, 0.08), transparent 50%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .service-card.active .card-glow, .service-card:hover .card-glow {
    opacity: 1;
  }

  .service-card:hover {
    transform: translateY(-8px);
    background: rgba(24, 28, 40, 0.7);
    border-color: rgba(163, 230, 53, 0.45);
    box-shadow: 
      0 20px 40px rgba(0, 0, 0, 0.5),
      0 0 20px rgba(163, 230, 53, 0.15);
  }

  .card-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .service-icon {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background: rgba(163, 230, 53, 0.05);
    border: 1px solid rgba(163, 230, 53, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-green);
    transition: all 0.3s ease;
  }

  .service-card:hover .service-icon {
    background: var(--accent-green);
    color: #060814;
    box-shadow: 0 0 15px rgba(163, 230, 53, 0.4);
    transform: scale(1.05);
  }

  .service-protocol {
    font-family: monospace;
    font-size: 0.7rem;
    font-weight: bold;
    color: var(--text-muted);
    letter-spacing: 1px;
  }

  .service-card:hover .service-protocol {
    color: var(--accent-green);
  }

  .service-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.2px;
  }

  .service-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .service-features {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: color 0.3s ease;
  }

  .service-card:hover .service-features li {
    color: var(--text-primary);
  }

  .feat-check {
    width: 16px;
    height: 16px;
    color: var(--accent-green);
    flex-shrink: 0;
    opacity: 0.8;
  }

  /* Responsive styling */
  @media (max-width: 992px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .service-card {
      padding: 2rem;
    }
  }
</style>
