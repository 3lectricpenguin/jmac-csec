---
// TechConsole.astro
---
<section id="console" class="console-section">
  <div class="console-container">
    <div class="console-header">
      <div class="section-label">
        <span class="label-number">02 //</span>
        <span class="label-text">SANDBOX ENV</span>
      </div>
      <h2 class="section-title">Interactive Terminal</h2>
      <p class="section-subtitle">
        Test our simulated network toolkit. Run vulnerability scans, decrypt packets, or review JCM protocols in real-time.
      </p>
    </div>

    <!-- Terminal Window -->
    <div class="terminal-window">
      <!-- Terminal Title Bar -->
      <div class="terminal-bar">
        <div class="window-buttons">
          <span class="win-btn close"></span>
          <span class="win-btn minimize"></span>
          <span class="win-btn maximize"></span>
        </div>
        <div class="terminal-title">guest@jcm-cybersecurity-node:~</div>
        <div class="terminal-status">SECURE CONNECTED</div>
      </div>
      
      <!-- Terminal Screen -->
      <div class="terminal-screen" id="terminal-screen">
        <div class="terminal-log">
          <div class="log-line system-welcome">JCM SECURE NETWORKING PROTOCOL [VERSION 2.40.1]</div>
          <div class="log-line system-welcome">© {new Date().getFullYear()} JCM IT Solutions. All access logged.</div>
          <div class="log-line system-welcome">Type <span class="cmd-highlight">help</span> for a list of available operations.</div>
          <br />
        </div>
        
        <!-- Terminal Input Line -->
        <div class="terminal-input-line">
          <span class="terminal-prompt">guest@jcm-node:~$</span>
          <input type="text" id="terminal-input" autofocus autocomplete="off" spellcheck="false" max-length="40" />
          <span class="custom-cursor"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const termInput = document.getElementById('terminal-input') as HTMLInputElement | null;
  const termScreen = document.getElementById('terminal-screen');
  const termLog = document.querySelector('.terminal-log');

  const COMMAND_LIST = {
    help: 'List of protocols: help, about, scan, decrypt, harden, clear',
    about: 'JCM IT Solutions: High-performance web development combined with professional-grade penetration testing and defensive engineering.',
    clear: '',
  };

  if (termInput && termScreen && termLog) {
    // Keep focus on input if clicking inside terminal
    termScreen.addEventListener('click', () => {
      termInput.focus();
    });

    termInput.addEventListener('keydown', async (e) => {
      if (e.key === 'Enter') {
        const inputVal = termInput.value.trim();
        const cmd = inputVal.toLowerCase();
        
        // Output prompt
        appendLog(`guest@jcm-node:~$ ${inputVal}`, 'user-cmd');
        termInput.value = '';

        if (cmd === '') return;

        if (cmd === 'clear') {
          termLog.innerHTML = '';
        } else if (cmd === 'help') {
          appendLog(COMMAND_LIST.help, 'sys-out');
        } else if (cmd === 'about') {
          appendLog(COMMAND_LIST.about, 'sys-out');
        } else if (cmd === 'scan') {
          termInput.disabled = true;
          await simulateScan();
          termInput.disabled = false;
          termInput.focus();
        } else if (cmd === 'decrypt') {
          termInput.disabled = true;
          await simulateDecrypt();
          termInput.disabled = false;
          termInput.focus();
        } else if (cmd === 'harden') {
          termInput.disabled = true;
          await simulateHarden();
          termInput.disabled = false;
          termInput.focus();
        } else {
          appendLog(`Error: command not found: "${inputVal}". Type "help" for instructions.`, 'sys-error');
        }

        // Scroll to bottom
        termScreen.scrollTop = termScreen.scrollHeight;
      }
    });

    function appendLog(text: string, className: string = '') {
      if (!termLog) return;
      const line = document.createElement('div');
      line.className = `log-line ${className}`;
      line.innerHTML = text;
      termLog.appendChild(line);
      if (termScreen) {
        termScreen.scrollTop = termScreen.scrollHeight;
      }
    }

    function sleep(ms: number) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function simulateScan() {
      appendLog('Initializing full systems audit...', 'sys-loader');
      await sleep(600);
      appendLog('Auditing firewall rules [IPTABLES]....... [ SECURE ]', 'sys-info');
      await sleep(400);
      appendLog('Auditing active web routes............. [ SECURE ]', 'sys-info');
      await sleep(400);
      appendLog('Scanning database ports [5432].......... [ SHIELDED ]', 'sys-info');
      await sleep(500);
      appendLog('Testing open socket ports............... [ 0 EXPOSED ]', 'sys-info');
      await sleep(600);
      appendLog('Vulnerability scan completed. Threat index: 0.00%', 'sys-success');
    }

    async function simulateDecrypt() {
      appendLog('Decrypting secure handshake stream...', 'sys-loader');
      await sleep(500);
      
      // Decrypt effect
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+';
      let decryptLine = document.createElement('div');
      decryptLine.className = 'log-line sys-decrypt-ticker';
      termLog?.appendChild(decryptLine);
      
      for (let i = 0; i < 4; i++) {
        let randStr = '';
        for (let j = 0; j < 35; j++) {
          randStr += chars[Math.floor(Math.random() * chars.length)];
        }
        decryptLine.innerText = `[HASH DECRYPT] ${randStr}`;
        await sleep(250);
      }
      
      decryptLine.innerText = '[HASH DECRYPT] jcm_auth_token_hash_ok :: verified';
      decryptLine.className = 'log-line sys-success';
    }

    async function simulateHarden() {
      appendLog('Executing defensive system hardening script...', 'sys-loader');
      await sleep(600);
      appendLog('1. Restricting root user SSH logins... OK', 'sys-info');
      await sleep(400);
      appendLog('2. Establishing secure rate-limiting on port 443... OK', 'sys-info');
      await sleep(400);
      appendLog('3. Rotating cryptography keys... OK', 'sys-info');
      await sleep(500);
      appendLog('Shielding operations complete. System level: MAX SECURE.', 'sys-success');
    }
  }
</script>

<style>
  .console-section {
    position: relative;
    padding: 6rem 2rem;
    background-color: var(--bg-primary);
  }

  .console-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .console-header {
    margin-bottom: 4rem;
    max-width: 650px;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .label-number {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-green);
  }

  .label-text {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .section-subtitle {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Terminal CSS wrapper */
  .terminal-window {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    background: rgba(13, 15, 23, 0.95);
    border: 1px solid rgba(163, 230, 53, 0.25);
    border-radius: 8px;
    box-shadow: 
      0 20px 50px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(163, 230, 53, 0.08);
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #12151f;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0.75rem 1.25rem;
    user-select: none;
  }

  .window-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .win-btn {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }

  .win-btn.close { background-color: #ef4444; }
  .win-btn.minimize { background-color: #f59e0b; }
  .win-btn.maximize { background-color: #10b981; }

  .terminal-title {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-secondary);
    letter-spacing: 0.5px;
  }

  .terminal-status {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--accent-green);
    background: rgba(163, 230, 53, 0.08);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    border: 1px solid rgba(163, 230, 53, 0.15);
  }

  .terminal-screen {
    height: 380px;
    padding: 1.5rem;
    overflow-y: auto;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9rem;
    color: #cbd5e1;
    line-height: 1.5;
    background: radial-gradient(circle at center, rgba(163, 230, 53, 0.02) 0%, transparent 80%);
  }

  /* Custom scrollbar for terminal */
  .terminal-screen::-webkit-scrollbar {
    width: 6px;
  }
  .terminal-screen::-webkit-scrollbar-track {
    background: transparent;
  }
  .terminal-screen::-webkit-scrollbar-thumb {
    background: rgba(163, 230, 53, 0.2);
    border-radius: 3px;
  }
  .terminal-screen::-webkit-scrollbar-thumb:hover {
    background: var(--accent-green);
  }

  .log-line {
    margin-bottom: 0.4rem;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .system-welcome {
    color: var(--text-secondary);
  }

  .cmd-highlight {
    color: var(--accent-green);
    font-weight: bold;
    text-shadow: 0 0 5px rgba(163, 230, 53, 0.3);
  }

  .user-cmd {
    color: #fff;
    font-weight: 600;
  }

  .sys-out {
    color: #94a3b8;
  }

  .sys-info {
    color: #94a3b8;
  }

  .sys-loader {
    color: var(--accent-green);
    opacity: 0.85;
  }

  .sys-success {
    color: var(--accent-green);
    font-weight: bold;
    text-shadow: 0 0 8px rgba(163, 230, 53, 0.4);
  }

  .sys-error {
    color: #ef4444;
  }

  .terminal-input-line {
    display: flex;
    align-items: center;
    position: relative;
  }

  .terminal-prompt {
    color: var(--accent-green);
    margin-right: 0.6rem;
    font-weight: bold;
  }

  #terminal-input {
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-family: inherit;
    font-size: inherit;
    padding: 0;
    margin: 0;
    flex-grow: 1;
    caret-color: transparent; /* custom cursor */
  }

  .custom-cursor {
    display: inline-block;
    width: 8px;
    height: 15px;
    background: var(--accent-green);
    animation: blink 0.8s infinite;
    position: absolute;
    /* align position to end of text */
    pointer-events: none;
  }

  /* Make custom cursor follow the input text width */
  #terminal-input:focus ~ .custom-cursor {
    display: none; /* Let standard or basic simulation handle caret, or hide default for clean look */
  }
  
  /* Fallback: using default caret is simpler and more responsive, we'll keep caret-color white */
  #terminal-input {
    caret-color: var(--accent-green);
  }
  .custom-cursor {
    display: none;
  }

  @keyframes blink {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }
</style>
