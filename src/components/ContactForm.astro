---
// ContactForm.astro
---
<section id="contact" class="contact-section">
  <div class="contact-container">
    <div class="contact-grid">
      <!-- Contact Info / Security Protocol Details -->
      <div class="contact-info">
        <div class="section-label">
          <span class="label-number">03 //</span>
          <span class="label-text">TRANSMISSION LINK</span>
        </div>
        <h2 class="section-title">Secure Communications</h2>
        <p class="contact-desc">
          Ready to secure your network or design your next web infrastructure? Initiate contact through our secure application form, or reach out directly via encrypted channels.
        </p>

        <div class="contact-channels">
          <!-- Direct Email -->
          <div class="channel-item">
            <div class="channel-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div class="channel-details">
              <span class="channel-lbl">DIRECT EMAIL</span>
              <a href="mailto:ops@jcm-itsolutions.com" class="channel-val">ops@jcm-itsolutions.com</a>
            </div>
          </div>

          <!-- Signal Protocol -->
          <div class="channel-item">
            <div class="channel-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
            </div>
            <div class="channel-details">
              <span class="channel-lbl">SECURE PROTOCOL</span>
              <span class="channel-val">Signal: @jcm_itsolutions.sec</span>
            </div>
          </div>

          <!-- Nodes -->
          <div class="channel-item">
            <div class="channel-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
            </div>
            <div class="channel-details">
              <span class="channel-lbl">SECTOR</span>
              <span class="channel-val">Remote Operations // EST Node</span>
            </div>
          </div>
        </div>

        <!-- Encryption PGP Fingerprint Box -->
        <div class="pgp-box">
          <div class="pgp-header">
            <span class="pgp-dot"></span>
            <span>PGP PUBLIC KEY FINGERPRINT</span>
          </div>
          <code class="pgp-code">
            EF4A 89CC 30D1 18FC 94A3<br/>
            6B7E A1C9 84CC A3E6 53F2
          </code>
        </div>
      </div>

      <!-- Secure Briefing Form -->
      <div class="contact-form-container">
        <form class="secure-form" id="secure-contact-form">
          <div class="form-row split">
            <div class="form-group">
              <label for="form-name">CLIENT IDENTIFIER</label>
              <input type="text" id="form-name" placeholder="Name or Organization" required />
              <span class="focus-line"></span>
            </div>
            <div class="form-group">
              <label for="form-email">SECURE ROUTING EMAIL</label>
              <input type="email" id="form-email" placeholder="client@domain.com" required />
              <span class="focus-line"></span>
            </div>
          </div>

          <div class="form-group">
            <label for="form-protocol">ENGAGEMENT PROTOCOL</label>
            <select id="form-protocol" required>
              <option value="" disabled selected>Select operation type...</option>
              <option value="web">Web Design & App Engineering</option>
              <option value="audit">Full-Scale Security Audit</option>
              <option value="pentesting">Tactical Penetration Testing</option>
              <option value="other">General IT Solutions Consultation</option>
            </select>
            <span class="focus-line"></span>
          </div>

          <div class="form-group">
            <label for="form-message">TRANSMISSION DATA BRIEFING</label>
            <textarea id="form-message" rows="5" placeholder="Outline your requirements, target scopes, or system vulnerabilities..." required></textarea>
            <span class="focus-line"></span>
          </div>

          <button type="submit" class="btn-submit">
            <span class="btn-text">INITIATE BRIEFING</span>
            <svg class="submit-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
          
          <div class="form-feedback" id="form-feedback-message"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('secure-contact-form');
  const feedback = document.getElementById('form-feedback-message');
  
  if (form && feedback) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Visual feedback response
      feedback.style.display = 'block';
      feedback.className = 'form-feedback success';
      feedback.innerHTML = '✔ TRANSMISSION SUCCESSFUL. SECURE DATA LINK OPENED. Our response team will correspond shortly.';
      
      // Reset form
      (form as HTMLFormElement).reset();
      
      setTimeout(() => {
        feedback.style.opacity = '0';
        setTimeout(() => {
          feedback.style.display = 'none';
          feedback.style.opacity = '1';
        }, 500);
      }, 5000);
    });
  }
</script>

<style>
  .contact-section {
    position: relative;
    padding: 6rem 2rem;
    background-color: var(--bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }

  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 4rem;
    align-items: center;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .label-number {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-green);
  }

  .label-text {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .contact-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .channel-item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .channel-icon {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-green);
    transition: all 0.3s ease;
  }

  .channel-item:hover .channel-icon {
    border-color: var(--accent-green);
    box-shadow: 0 0 10px rgba(163, 230, 53, 0.2);
    background: rgba(163, 230, 53, 0.05);
  }

  .channel-details {
    display: flex;
    flex-direction: column;
  }

  .channel-lbl {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: bold;
    color: var(--text-muted);
    letter-spacing: 1px;
  }

  .channel-val {
    font-size: 0.95rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s;
  }

  a.channel-val:hover {
    color: var(--accent-green);
    text-shadow: 0 0 5px rgba(163, 230, 53, 0.2);
  }

  /* PGP Box Styling */
  .pgp-box {
    background: rgba(10, 11, 16, 0.6);
    border: 1px dashed rgba(163, 230, 53, 0.25);
    border-radius: 6px;
    padding: 1.25rem;
    max-width: 380px;
  }

  .pgp-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: bold;
    color: var(--accent-green);
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .pgp-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 5px var(--accent-green);
  }

  .pgp-code {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  /* Contact Form Container */
  .contact-form-container {
    background: rgba(24, 28, 40, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 3rem;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
  }

  .secure-form {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .form-row {
    display: flex;
    gap: 1.5rem;
  }

  .form-row.split .form-group {
    flex: 1;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .form-group label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: bold;
    letter-spacing: 1px;
    color: var(--text-secondary);
    margin-bottom: 0.6rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: rgba(10, 11, 16, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    padding: 0.9rem 1.1rem;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  /* Remove default styling for select arrow */
  .form-group select {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg fill='white' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/><path d='M0 0h24v24H0z' fill='none'/></svg>");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1.25rem;
    padding-right: 2.5rem;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: rgba(163, 230, 53, 0.6);
    box-shadow: 0 0 10px rgba(163, 230, 53, 0.15);
    background: #0a0b10;
  }

  .focus-line {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1.5px;
    background: var(--accent-green);
    transition: all 0.3s ease;
  }

  .form-group input:focus ~ .focus-line,
  .form-group select:focus ~ .focus-line,
  .form-group textarea:focus ~ .focus-line {
    left: 0;
    width: 100%;
  }

  /* Submit Button */
  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    padding: 1.1rem 2.5rem;
    background: transparent;
    border: 1px solid var(--accent-green);
    border-radius: 4px;
    color: var(--accent-green);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 0 10px rgba(163, 230, 53, 0.08);
  }

  .btn-submit:hover {
    background: var(--accent-green);
    color: #060814;
    box-shadow: 0 0 25px rgba(163, 230, 53, 0.4);
    transform: translateY(-2px);
  }

  .submit-arrow {
    transition: transform 0.3s ease;
  }

  .btn-submit:hover .submit-arrow {
    transform: translateX(4px);
  }

  /* Feedback box */
  .form-feedback {
    display: none;
    padding: 1rem;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.8rem;
    margin-top: 1rem;
    transition: opacity 0.5s ease;
  }

  .form-feedback.success {
    background: rgba(163, 230, 53, 0.08);
    border: 1px solid rgba(163, 230, 53, 0.3);
    color: var(--accent-green);
  }

  /* Responsive Styling */
  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .contact-form-container {
      padding: 2rem;
    }
  }

  @media (max-width: 576px) {
    .form-row.split {
      flex-direction: column;
      gap: 1.8rem;
    }
  }
</style>
