---
// ContactForm.astro
---
<section id="contact" class="contact-section">
  <div class="contact-container">
    <div class="contact-grid">
      <!-- Contact Info -->
      <div class="contact-info">
        <div class="section-label">
          <span class="label-number">03 //</span>
          <span class="label-text">GET IN TOUCH</span>
        </div>
        <h2 class="section-title">Start a Conversation</h2>
        <p class="contact-desc">
          Have a project in mind, need to secure your systems, or looking for general IT support? Feel free to reach out via the form, or email us directly.
        </p>

        <div class="contact-channels">
          <!-- Direct Email -->
          <div class="channel-item">
            <div class="channel-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div class="channel-details">
              <span class="channel-lbl">DIRECT EMAIL</span>
              <a href="mailto:jmac.itsec@gmail.com" class="channel-val">jmac.itsec@gmail.com</a>
            </div>
          </div>

          <!-- Response Time -->
          <div class="channel-item">
            <div class="channel-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div class="channel-details">
              <span class="channel-lbl">RESPONSE TIME</span>
              <span class="channel-val">Usually within 24 hours</span>
            </div>
          </div>

          <!-- Service Coverage -->
          <div class="channel-item">
            <div class="channel-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div class="channel-details">
              <span class="channel-lbl">SERVICE COVERAGE</span>
              <span class="channel-val">Remote & Physical Support in Ohio, Michigan, and Indiana.</span>
            </div>
          </div>
        </div>

        <!-- Privacy Guarantee Box -->
        <div class="privacy-box">
          <div class="privacy-header">
            <span class="privacy-dot"></span>
            <span>PRIVACY & CONFIDENTIALITY</span>
          </div>
          <p class="privacy-text">
            Your connection is secure. All messages are encrypted in transit and handled with strict confidentiality.
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-container">
        <form class="secure-form" id="secure-contact-form" action="https://submit.jotform.com/submit/261798536543066" method="POST">
          <!-- Jotform ID & Helper fields -->
          <input type="hidden" name="formID" value="261798536543066" />
          <input type="hidden" class="simple_spc" id="simple_spc" name="simple_spc" value="261798536543066-261798536543066" />
          
          <div class="form-row split">
            <div class="form-group">
              <label for="form-name">YOUR NAME / COMPANY</label>
              <input type="text" id="form-name" name="q5_yourName" placeholder="John Doe or Acme Corp" required />
              <span class="focus-line"></span>
            </div>
            <div class="form-group">
              <label for="form-email">YOUR EMAIL ADDRESS</label>
              <input type="email" id="form-email" name="q6_yourEmail" placeholder="you@domain.com" required />
              <span class="focus-line"></span>
            </div>
          </div>

          <div class="form-group">
            <label for="form-protocol">WHAT DO YOU NEED HELP WITH?</label>
            <select id="form-protocol" name="q8_whatDo" required>
              <option value="" disabled selected>Select a service...</option>
              <option value="Web Design & Development">Web Design & Development</option>
              <option value="Security Audit & Assessment">Security Audit & Assessment</option>
              <option value="Penetration Testing (Ethical Hacking)">Penetration Testing (Ethical Hacking)</option>
              <option value="IT Consulting & Support">IT Consulting & Support</option>
            </select>
            <span class="focus-line"></span>
          </div>

          <div class="form-group">
            <label for="form-message">PROJECT DETAILS / MESSAGE</label>
            <textarea id="form-message" name="q9_projectDetails" rows="5" placeholder="Tell us about your project, goals, or what you need assistance with..." required></textarea>
            <span class="focus-line"></span>
          </div>

          <button type="submit" class="btn-submit">
            <span class="btn-text">SEND MESSAGE</span>
            <svg class="submit-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
          
          <div class="form-feedback" id="form-feedback-message"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('secure-contact-form');
  const feedback = document.getElementById('form-feedback-message');
  
  if (form && feedback) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form as HTMLFormElement);
      
      // Submit via fetch to Jotform (no-cors mode to allow redirect responses)
      fetch('https://submit.jotform.com/submit/261798536543066', {
        method: 'POST',
        body: formData,
        mode: 'no-cors'
      })
      .then(() => {
        // Visual feedback response
        feedback.style.display = 'block';
        feedback.className = 'form-feedback success';
        feedback.innerHTML = '✔ Message sent successfully! We will get back to you shortly.';
        
        // Reset form
        (form as HTMLFormElement).reset();
        
        setTimeout(() => {
          feedback.style.opacity = '0';
          setTimeout(() => {
            feedback.style.display = 'none';
            feedback.style.opacity = '1';
          }, 500);
        }, 5000);
      })
      .catch((error) => {
        console.error('Submission error:', error);
        feedback.style.display = 'block';
        feedback.className = 'form-feedback error';
        feedback.innerHTML = '❌ An error occurred. Please try again or email us directly.';
      });
    });
  }
</script>

<style>
  .contact-section {
    position: relative;
    padding: 6rem 2rem;
    background-color: var(--bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }

  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 4rem;
    align-items: center;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .label-number {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-green);
  }

  .label-text {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .contact-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .channel-item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .channel-icon {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-green);
    transition: all 0.3s ease;
  }

  .channel-item:hover .channel-icon {
    border-color: var(--accent-green);
    box-shadow: 0 0 10px rgba(163, 230, 53, 0.2);
    background: rgba(163, 230, 53, 0.05);
  }

  .channel-details {
    display: flex;
    flex-direction: column;
  }

  .channel-lbl {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: bold;
    color: var(--text-muted);
    letter-spacing: 1px;
  }

  .channel-val {
    font-size: 0.95rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s;
  }

  a.channel-val:hover {
    color: var(--accent-green);
    text-shadow: 0 0 5px rgba(163, 230, 53, 0.2);
  }

  /* Privacy Box Styling */
  .privacy-box {
    background: rgba(10, 11, 16, 0.6);
    border: 1px dashed rgba(163, 230, 53, 0.25);
    border-radius: 6px;
    padding: 1.25rem;
    max-width: 380px;
  }

  .privacy-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: bold;
    color: var(--accent-green);
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .privacy-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 5px var(--accent-green);
  }

  .privacy-text {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* Contact Form Container */
  .contact-form-container {
    background: rgba(24, 28, 40, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 3rem;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
  }

  .secure-form {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .form-row {
    display: flex;
    gap: 1.5rem;
  }

  .form-row.split .form-group {
    flex: 1;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .form-group label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: bold;
    letter-spacing: 1px;
    color: var(--text-secondary);
    margin-bottom: 0.6rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: rgba(10, 11, 16, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    padding: 0.9rem 1.1rem;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  /* Remove default styling for select arrow */
  .form-group select {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg fill='white' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/><path d='M0 0h24v24H0z' fill='none'/></svg>");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1.25rem;
    padding-right: 2.5rem;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: rgba(163, 230, 53, 0.6);
    box-shadow: 0 0 10px rgba(163, 230, 53, 0.15);
    background: #0a0b10;
  }

  .focus-line {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1.5px;
    background: var(--accent-green);
    transition: all 0.3s ease;
  }

  .form-group input:focus ~ .focus-line,
  .form-group select:focus ~ .focus-line,
  .form-group textarea:focus ~ .focus-line {
    left: 0;
    width: 100%;
  }

  /* Submit Button */
  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    padding: 1.1rem 2.5rem;
    background: transparent;
    border: 1px solid var(--accent-green);
    border-radius: 4px;
    color: var(--accent-green);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 0 10px rgba(163, 230, 53, 0.08);
  }

  .btn-submit:hover {
    background: var(--accent-green);
    color: #060814;
    box-shadow: 0 0 25px rgba(163, 230, 53, 0.4);
    transform: translateY(-2px);
  }

  .submit-arrow {
    transition: transform 0.3s ease;
  }

  .btn-submit:hover .submit-arrow {
    transform: translateX(4px);
  }

  /* Feedback box */
  .form-feedback {
    display: none;
    padding: 1rem;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.8rem;
    margin-top: 1rem;
    transition: opacity 0.5s ease;
  }

  .form-feedback.success {
    background: rgba(163, 230, 53, 0.08);
    border: 1px solid rgba(163, 230, 53, 0.3);
    color: var(--accent-green);
  }

  .form-feedback.error {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #ef4444;
  }

  /* Responsive Styling */
  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .contact-form-container {
      padding: 2rem;
    }
  }

  @media (max-width: 576px) {
    .form-row.split {
      flex-direction: column;
      gap: 1.8rem;
    }
  }
</style>
