---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cyber CTF | Black Penguin IT Security" description="Test your cybersecurity skills on the Black Penguin CTF platform. Solve challenges in cryptography, web security, reverse engineering, and SQL injection.">
  <div class="ctf-page-wrapper">
    <!-- Particles/Cyber grid background -->
    <div class="cyber-grid-overlay"></div>

    <div class="ctf-main-container">
      
      <!-- 1. ENTRY PORTAL (Nickname Selection) -->
      <div id="ctf-entry-portal" class="ctf-card portal-card">
        <div class="card-header-accent">
          <span class="glitch-text" data-text="INITIALIZE OPERATION">INITIALIZE OPERATION</span>
        </div>
        <div class="portal-body">
          <div class="portal-logo">
            <svg viewBox="0 0 100 100" class="portal-svg" xmlns="http://www.w3.org/2000/svg">
              <polygon points="50,5 90,25 90,75 50,95 10,75 10,25" stroke="var(--accent-green)" stroke-width="4" stroke-linejoin="round" fill="none"/>
              <path d="M50,25 L70,45 L70,70 L50,85 L30,70 L30,45 Z" fill="none" stroke="var(--accent-green)" stroke-width="2" stroke-linejoin="round" stroke-dasharray="2,2"/>
              <circle cx="50" cy="50" r="10" stroke="var(--accent-green)" stroke-width="2" fill="none"/>
            </svg>
          </div>
          <h3>SECURE OPERATOR ACCESS</h3>
          <p class="portal-desc">
            Welcome to the Black Penguin Sandbox CTF environment. Enter an operator nickname to log in, initialize tracking protocols, and access the challenges.
          </p>
          <form id="nickname-form" class="portal-form">
            <div class="input-wrapper">
              <label for="operator-nickname">OPERATOR NICKNAME</label>
              <input type="text" id="operator-nickname" placeholder="e.g., Guest_Hacker" maxlength="15" required autocomplete="off" />
              <span class="input-focus-line"></span>
            </div>
            <button type="submit" class="btn-portal-submit">
              <span>ACCESS WORKSPACE</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </form>
        </div>
      </div>

      <!-- 2. CTF WORKSPACE (Hidden initially) -->
      <div id="ctf-workspace" class="workspace-grid" style="display: none;">
        
        <!-- Sidebar: Stats & Leaderboard -->
        <div class="workspace-sidebar">
          
          <!-- Operator Profile Card -->
          <div class="ctf-card profile-card">
            <div class="profile-header">
              <div class="avatar-glow"></div>
              <div class="profile-text">
                <span class="profile-label">OPERATOR STATUS</span>
                <h4 id="display-nickname">GUEST_USER</h4>
              </div>
            </div>
            <div class="profile-stats">
              <div class="stat-box">
                <span class="stat-label">TOTAL SCORE</span>
                <span class="stat-value" id="player-score">0 pts</span>
              </div>
              <div class="stat-box">
                <span class="stat-label">ELAPSED TIME</span>
                <span class="stat-value" id="elapsed-time">00:00</span>
              </div>
            </div>
            <div class="progress-bar-container">
              <div class="progress-bar-fill" id="player-progress" style="width: 0%;"></div>
            </div>
            <div class="progress-label">
              <span>COMPLETION</span>
              <span id="player-percent">0%</span>
            </div>
            <button id="abort-session-btn" class="btn-abort">ABORT OPERATION</button>
          </div>

          <!-- Top Hackers Leaderboard -->
          <div class="ctf-card leaderboard-card">
            <div class="card-title">
              <span class="title-indicator"></span>
              <h4>TOP HACKERS</h4>
              <span class="live-pulse">LIVE</span>
            </div>
            <div class="leaderboard-list" id="leaderboard-rows">
              <!-- Dynamically populated -->
            </div>
          </div>

          <!-- Hack Logs (Feed of system events) -->
          <div class="ctf-card logs-card">
            <div class="card-title">
              <span class="title-indicator"></span>
              <h4>SYSTEM LOGS</h4>
            </div>
            <div class="log-feed" id="system-log-feed">
              <div class="log-entry system">[SYSTEM] Protocols loaded. Waiting for initialization...</div>
            </div>
          </div>

        </div>

        <!-- Main Workspace: Challenge Selection & Details -->
        <div class="workspace-main">
          
          <!-- Challenge Selector Cards -->
          <div class="challenges-section">
            <div class="section-header">
              <h3>ACTIVE CHALLENGES</h3>
              <p>Select a challenge to open the sandbox terminal and solve it.</p>
            </div>
            <div class="challenges-grid" id="challenges-list">
              <!-- Dynamically populated -->
            </div>
          </div>

          <!-- Challenge Details Panel (now a modal overlay) -->
          <div class="challenge-overlay" id="challenge-details-panel" style="display: none;">
            <div class="overlay-backdrop" id="overlay-backdrop"></div>
            <div class="ctf-card details-card overlay-content">
              <button class="btn-close-overlay" id="close-overlay-btn" type="button" aria-label="Close panel">
                <span>CLOSE</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>

              <div class="details-content" id="details-content-state" style="display: none;">
                <div class="challenge-meta">
                  <span class="challenge-points-badge" id="detail-points">0 pts</span>
                  <span class="challenge-category-badge" id="detail-category">GENERAL</span>
                </div>
                <h2 id="detail-title" class="challenge-title">Challenge Title</h2>
                <p id="detail-desc" class="challenge-desc">Challenge description goes here.</p>
                
                <!-- Interactive Workspace for Challenge -->
                <div class="challenge-sandbox" id="challenge-sandbox-container">
                  <!-- Inner sandbox changes depending on selected challenge -->
                </div>

                <!-- Submit Form -->
                <div class="challenge-submission-box" id="submission-box">
                  <form id="flag-submit-form" class="submission-form">
                    <div class="flag-input-group">
                      <input type="text" id="flag-input" placeholder="FLAG{...}" required autocomplete="off" />
                      <button type="submit" class="btn-submit-flag">SUBMIT FLAG</button>
                    </div>
                    <div class="flag-feedback" id="flag-feedback-msg"></div>
                  </form>
                </div>
              </div>
            </div>
          </div>

        </div>

      </div>

    </div>
  </div>
</Layout>

<script>
  // Challenges database
  interface Challenge {
    id: number;
    title: string;
    points: number;
    category: string;
    description: string;
    hint: string;
    flag: string;
    solved: boolean;
  }

  const challenges: Challenge[] = [
    {
      id: 1,
      title: "Secret in the Source",
      points: 5,
      category: "Web Recon",
      description: "Developers often leave sensitive comments or debug information in the page source. Inspect this card's DOM structure or look closely for hidden comments to find the flag.",
      hint: "Right-click -> Inspect, or view the source of the elements inside this challenge box. There is an HTML comment waiting for you.",
      flag: "FLAG{s3cr3t_s0urc3_5pts}",
      solved: false
    },
    {
      id: 2,
      title: "Cypher Decoder",
      points: 10,
      category: "Cryptography",
      description: "We intercepted a Base64-encoded payload from a command-and-control server. Decode the string to retrieve the raw flag: <br/><code class='cyber-code'>RkxBR3tiYXM2NF9kZWNvZGVyXzEwcHRzfQ==</code>",
      hint: "Base64 is a binary-to-text representation. You can decode it in JavaScript using the `atob()` function in the console, or use a decoder tool.",
      flag: "FLAG{bas64_decoder_10pts}",
      solved: false
    },
    {
      id: 3,
      title: "Logic Bypass",
      points: 20,
      category: "Reverse Engineering",
      description: "An authentication gate checks a password. The Javascript function validating the entry is reversed: <br/><code class='cyber-code'>function check(pass) { return pass.split('').reverse().join('') === 'n1ugn3p_kc4lb'; }</code><br/>Find the correct password and submit it in the input panel below to get the flag.",
      hint: "Reverse the target string 'n1ugn3p_kc4lb' to discover the correct password. Be sure to check letters and numbers carefully.",
      flag: "FLAG{js_obfuscation_20pts}",
      solved: false
    },
    {
      id: 4,
      title: "Caesar's Vault",
      points: 35,
      category: "Cryptography",
      description: "A message was encrypted using a Caesar cipher (rotational offset shift of +7). Decrypt the cipher text to find the flag: <br/><code class='cyber-code'>MSHN{jhlzhy_jpwoly_35waz}</code>",
      hint: "For each character in the message, shift it backward by 7 positions in the alphabet. M -> F, S -> L, H -> A, N -> G, and so on.",
      flag: "FLAG{caesar_cipher_35pts}",
      solved: false
    },
    {
      id: 5,
      title: "SQL Injection Panel",
      points: 50,
      category: "Web Exploitation",
      description: "We found a administrative login page. The database query is constructed insecurely as: <br/><code class='cyber-code'>SELECT * FROM users WHERE username = '${user}' AND password = '${pass}'</code><br/>Inject SQL commands into the Username field to bypass verification, log in as `admin`, and extract the secret flag.",
      hint: "Injecting `' OR '1'='1` or `' OR 1=1 --` into the username field will force the SQL statement to evaluate to true, bypassing password checks.",
      flag: "FLAG{sqli_bypass_50pts_winner}",
      solved: false
    }
  ];

  // Leaderboard data
  interface Hacker {
    name: string;
    points: number;
    time: number; // in seconds
    isPlayer?: boolean;
    solvedCount: number;
  }

  let hackers: Hacker[] = [
    { name: "acid_burn", points: 70, time: 165, solvedCount: 3 },
    { name: "zero_cool", points: 55, time: 242, solvedCount: 3 },
    { name: "cereal_killer", points: 35, time: 125, solvedCount: 2 },
    { name: "lord_nikon", points: 15, time: 92, solvedCount: 2 },
    { name: "crash_override", points: 5, time: 32, solvedCount: 1 },
    { name: "phantom_phreak", points: 0, time: 0, solvedCount: 0 }
  ];

  let nickname = "";
  let playerScore = 0;
  let playerTime = 0; // seconds
  let timerInterval: any = null;
  let selectedChallengeId: number | null = null;
  let startTime = 0;

  // DOM Elements
  const entryPortal = document.getElementById('ctf-entry-portal') as HTMLElement;
  const workspace = document.getElementById('ctf-workspace') as HTMLElement;
  const nicknameForm = document.getElementById('nickname-form') as HTMLFormElement;
  const nicknameInput = document.getElementById('operator-nickname') as HTMLInputElement;
  const displayNickname = document.getElementById('display-nickname') as HTMLElement;
  const playerProgress = document.getElementById('player-progress') as HTMLElement;
  const playerPercent = document.getElementById('player-percent') as HTMLElement;
  const playerScoreEl = document.getElementById('player-score') as HTMLElement;
  const elapsedTimeEl = document.getElementById('elapsed-time') as HTMLElement;
  const abortBtn = document.getElementById('abort-session-btn') as HTMLButtonElement;
  const leaderboardRows = document.getElementById('leaderboard-rows') as HTMLElement;
  const logFeed = document.getElementById('system-log-feed') as HTMLElement;
  const challengesList = document.getElementById('challenges-list') as HTMLElement;

  // Challenge Details DOM
  const overlayPanel = document.getElementById('challenge-details-panel') as HTMLElement;
  const closeOverlayBtn = document.getElementById('close-overlay-btn') as HTMLButtonElement;
  const overlayBackdrop = document.getElementById('overlay-backdrop') as HTMLElement;
  const detailsContent = document.getElementById('details-content-state') as HTMLElement;
  const detailPoints = document.getElementById('detail-points') as HTMLElement;
  const detailCategory = document.getElementById('detail-category') as HTMLElement;
  const detailTitle = document.getElementById('detail-title') as HTMLElement;
  const detailDesc = document.getElementById('detail-desc') as HTMLElement;
  const sandboxContainer = document.getElementById('challenge-sandbox-container') as HTMLElement;
  const submissionBox = document.getElementById('submission-box') as HTMLElement;
  const flagForm = document.getElementById('flag-submit-form') as HTMLFormElement;
  const flagInput = document.getElementById('flag-input') as HTMLInputElement;
  const flagFeedback = document.getElementById('flag-feedback-msg') as HTMLElement;

  const closeOverlay = () => {
    if (overlayPanel) overlayPanel.style.display = 'none';
    document.body.style.overflow = ''; // Unlock background scroll
    selectedChallengeId = null;
    // Remove active highlight from cards
    const selectorCards = document.querySelectorAll('.challenge-selector-card');
    selectorCards.forEach(card => card.classList.remove('active'));
  };

  if (closeOverlayBtn) {
    closeOverlayBtn.addEventListener('click', closeOverlay);
  }
  if (overlayBackdrop) {
    overlayBackdrop.addEventListener('click', closeOverlay);
  }

  // Initialize page
  function init() {
    const savedNickname = localStorage.getItem('ctf_nickname');
    const savedScore = localStorage.getItem('ctf_score');
    const savedTime = localStorage.getItem('ctf_elapsed');
    const savedSolved = localStorage.getItem('ctf_solved_ids');

    if (savedNickname) {
      nickname = savedNickname;
      playerScore = parseInt(savedScore || '0');
      playerTime = parseInt(savedTime || '0');
      
      const solvedIds = JSON.parse(savedSolved || '[]');
      challenges.forEach(c => {
        if (solvedIds.includes(c.id)) {
          c.solved = true;
        }
      });

      startTime = Date.now() - (playerTime * 1000);
      startWorkspace();
    }
  }

  // Handle Nickname Submission
  nicknameForm.addEventListener('submit', (e) => {
    e.preventDefault();
    nickname = nicknameInput.value.trim().replace(/[^a-zA-Z0-9_]/g, '');
    if (!nickname) return;

    localStorage.setItem('ctf_nickname', nickname);
    localStorage.setItem('ctf_score', '0');
    localStorage.setItem('ctf_elapsed', '0');
    localStorage.setItem('ctf_solved_ids', '[]');
    
    startTime = Date.now();
    playerTime = 0;
    playerScore = 0;
    challenges.forEach(c => c.solved = false);

    // Setup initial leaderboard status for player
    const existingPlayerIndex = hackers.findIndex(h => h.isPlayer);
    if (existingPlayerIndex > -1) hackers.splice(existingPlayerIndex, 1);
    
    startWorkspace();
    addLog(`[SYSTEM] Operator session initialized for ${nickname}`, 'system');
  });

  // Abort operation
  abortBtn.addEventListener('click', () => {
    localStorage.removeItem('ctf_nickname');
    localStorage.removeItem('ctf_score');
    localStorage.removeItem('ctf_elapsed');
    localStorage.removeItem('ctf_solved_ids');
    clearInterval(timerInterval);
    
    entryPortal.style.display = 'block';
    workspace.style.display = 'none';
    document.body.style.overflow = '';
    if (overlayPanel) overlayPanel.style.display = 'none';
  });

  // Switch display and start loops
  function startWorkspace() {
    entryPortal.style.display = 'none';
    workspace.style.display = 'grid';
    displayNickname.textContent = nickname.toUpperCase();
    
    // Build challenges grid
    renderChallengesList();

    // Start Timer
    clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      playerTime = Math.floor((Date.now() - startTime) / 1000);
      localStorage.setItem('ctf_elapsed', playerTime.toString());
      updateTimerDisplay();
    }, 1000);

    // Draw Leaderboard
    updateLeaderboard();

    // Simulated background bot actions
    startBotSimulations();
  }

  function updateTimerDisplay() {
    const mins = Math.floor(playerTime / 60).toString().padStart(2, '0');
    const secs = (playerTime % 60).toString().padStart(2, '0');
    elapsedTimeEl.textContent = `${mins}:${secs}`;
  }

  function addLog(text: string, type: 'system' | 'success' | 'warning' | 'alert') {
    const entry = document.createElement('div');
    entry.className = `log-entry ${type}`;
    const timestamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    entry.innerHTML = `<span class="log-time">[${timestamp}]</span> ${text}`;
    logFeed.appendChild(entry);
    logFeed.scrollTop = logFeed.scrollHeight;
  }

  function getChallengeIcon(id: number) {
    if (id === 1) {
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`;
    } else if (id === 2) {
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`;
    } else if (id === 3) {
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`;
    } else if (id === 4) {
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`;
    } else {
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"></path></svg>`;
    }
  }

  // Render the challenge nodes in grid
  function renderChallengesList() {
    challengesList.innerHTML = '';
    challenges.forEach(challenge => {
      const card = document.createElement('div');
      card.className = `challenge-selector-card service-card ${challenge.solved ? 'solved' : ''} ${selectedChallengeId === challenge.id ? 'active' : ''}`;
      card.setAttribute('data-id', challenge.id.toString());
      
      card.innerHTML = `
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="service-icon">
              ${getChallengeIcon(challenge.id)}
            </div>
            <span class="service-protocol">[ NODE-0${challenge.id} // ${challenge.points} PTS ]</span>
          </div>
          <h3 class="service-name">${challenge.category}</h3>
          <p class="service-desc">${challenge.title}</p>
          <div class="selector-footer">
            <span class="selector-status-text">
              ${challenge.solved ? '● SECURED' : '○ DISCONNECTED'}
            </span>
            <span class="selector-action-btn">
              ${challenge.solved ? 'REVIEW' : 'CHALLENGE ❯'}
            </span>
          </div>
        </div>
      `;

      card.addEventListener('click', () => {
        selectChallenge(challenge.id);
      });

      challengesList.appendChild(card);
    });

    updateProgress();
  }

  function updateProgress() {
    const totalSolved = challenges.filter(c => c.solved).length;
    const progressPercent = Math.round((totalSolved / challenges.length) * 100);
    playerPercent.textContent = `${progressPercent}%`;
    playerProgress.style.width = `${progressPercent}%`;
    playerScoreEl.textContent = `${playerScore} pts`;
  }

  // Load a single challenge into details view
  function selectChallenge(id: number) {
    selectedChallengeId = id;
    const challenge = challenges.find(c => c.id === id);
    if (!challenge) return;

    // Highlights selected card
    const selectorCards = document.querySelectorAll('.challenge-selector-card');
    selectorCards.forEach(card => {
      if (parseInt(card.getAttribute('data-id') || '0') === id) {
        card.classList.add('active');
      } else {
        card.classList.remove('active');
      }
    });

    if (overlayPanel) {
      overlayPanel.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    detailsContent.style.display = 'block';

    detailPoints.textContent = `${challenge.points} pts`;
    detailCategory.textContent = challenge.category.toUpperCase();
    detailTitle.textContent = challenge.title;
    detailDesc.innerHTML = challenge.description;

    // Reset submission state
    flagInput.value = '';
    flagFeedback.style.display = 'none';
    
    if (challenge.solved) {
      submissionBox.style.display = 'none';
      flagFeedback.style.display = 'block';
      flagFeedback.className = 'flag-feedback success-text';
      flagFeedback.textContent = 'Challenge Node Secured. Flag verified.';
    } else {
      submissionBox.style.display = 'block';
    }

    // Build specific interactive sandbox
    loadSandbox(challenge);
  }

  // Custom sandbox for each challenge
  function loadSandbox(challenge: Challenge) {
    sandboxContainer.innerHTML = '';
    
    if (challenge.id === 1) {
      // Challenge 1: HTML Comment
      const wrapper = document.createElement('div');
      wrapper.className = 'sandbox-inner html-sandbox';
      wrapper.innerHTML = `
        <div class="interactive-prompt">
          <span>CONSOLE: DOM inspector active. Scan for comments.</span>
        </div>
        <div class="element-viewer">
          <p>Analyzing sub-nodes...</p>
          <span class="muted-tag">&lt;div class="node-root"&gt;</span>
          <div class="nested-node">
            <span class="muted-tag">&lt;span class="cyber-badge"&gt;Black Penguin Security Node&lt;/span&gt;</span>
            <!-- Flag: FLAG{s3cr3t_s0urc3_5pts} -->
            <p class="cyber-inspect-hint">Node structure secure. All systems green.</p>
          </div>
          <span class="muted-tag">&lt;/div&gt;</span>
        </div>
      `;
      sandboxContainer.appendChild(wrapper);
    } 
    else if (challenge.id === 2) {
      // Challenge 2: Base64 Decrypt
      const wrapper = document.createElement('div');
      wrapper.className = 'sandbox-inner crypto-sandbox';
      wrapper.innerHTML = `
        <div class="interactive-prompt">
          <span>CONSOLE: Base64 decoder tool.</span>
        </div>
        <div class="decoder-tool">
          <input type="text" id="base64-input" placeholder="Enter base64 to decode..." class="sandbox-input" />
          <button id="base64-btn" class="btn-sandbox">DECODE</button>
          <div id="base64-output" class="sandbox-output">Result: </div>
        </div>
      `;
      sandboxContainer.appendChild(wrapper);

      const b64Input = wrapper.querySelector('#base64-input') as HTMLInputElement;
      const b64Btn = wrapper.querySelector('#base64-btn') as HTMLButtonElement;
      const b64Output = wrapper.querySelector('#base64-output') as HTMLElement;

      b64Btn.addEventListener('click', () => {
        try {
          const val = b64Input.value.trim();
          if (val) {
            b64Output.textContent = `Result: ${atob(val)}`;
            b64Output.className = "sandbox-output success-val";
          }
        } catch(e) {
          b64Output.textContent = `Result: Decode failed. Invalid Base64 format.`;
          b64Output.className = "sandbox-output error-val";
        }
      });
    }
    else if (challenge.id === 3) {
      // Challenge 3: Logic Bypass
      const wrapper = document.createElement('div');
      wrapper.className = 'sandbox-inner rev-sandbox';
      wrapper.innerHTML = `
        <div class="interactive-prompt">
          <span>CONSOLE: Authenticator gate check. Enter correct password.</span>
        </div>
        <div class="login-bypass-panel">
          <div class="bypass-row">
            <input type="text" id="bypass-password" placeholder="Enter gate password..." class="sandbox-input" />
            <button id="bypass-btn" class="btn-sandbox">UNLOCK</button>
          </div>
          <div id="bypass-output" class="sandbox-output">Status: LOCKED</div>
        </div>
      `;
      sandboxContainer.appendChild(wrapper);

      const passInput = wrapper.querySelector('#bypass-password') as HTMLInputElement;
      const passBtn = wrapper.querySelector('#bypass-btn') as HTMLButtonElement;
      const passOutput = wrapper.querySelector('#bypass-output') as HTMLElement;

      passBtn.addEventListener('click', () => {
        const val = passInput.value.trim();
        if (val.split('').reverse().join('') === 'n1ugn3p_kc4lb') {
          passOutput.innerHTML = `STATUS: UNLOCKED<br/><span style="color:var(--accent-green);font-weight:bold;">FLAG: FLAG{js_obfuscation_20pts}</span>`;
          passOutput.className = "sandbox-output success-val";
          addLog('[SUCCESS] Authenticator gate bypassed successfully.', 'success');
        } else {
          passOutput.textContent = `STATUS: ACCESS DENIED. Password incorrect.`;
          passOutput.className = "sandbox-output error-val";
        }
      });
    }
    else if (challenge.id === 4) {
      // Challenge 4: Caesar shift
      const wrapper = document.createElement('div');
      wrapper.className = 'sandbox-inner crypto-sandbox';
      wrapper.innerHTML = `
        <div class="interactive-prompt">
          <span>CONSOLE: Rotational cipher decryptor helper.</span>
        </div>
        <div class="caesar-tool">
          <div class="caesar-controls">
            <input type="text" id="caesar-text" value="MSHN{jhlzhy_jpwoly_35waz}" class="sandbox-input" style="flex: 1;" />
            <div class="shift-selector">
              <label>Shift:</label>
              <input type="number" id="caesar-shift" value="-7" min="-25" max="25" class="sandbox-input number-input" />
            </div>
            <button id="caesar-btn" class="btn-sandbox">SHIFT</button>
          </div>
          <div id="caesar-output" class="sandbox-output">Result: </div>
        </div>
      `;
      sandboxContainer.appendChild(wrapper);

      const txtInput = wrapper.querySelector('#caesar-text') as HTMLInputElement;
      const shInput = wrapper.querySelector('#caesar-shift') as HTMLInputElement;
      const caesarBtn = wrapper.querySelector('#caesar-btn') as HTMLButtonElement;
      const caesarOutput = wrapper.querySelector('#caesar-output') as HTMLElement;

      caesarBtn.addEventListener('click', () => {
        const txt = txtInput.value;
        const shift = parseInt(shInput.value) || 0;
        
        let result = '';
        for (let i = 0; i < txt.length; i++) {
          const char = txt[i];
          if (char.match(/[a-z]/i)) {
            const code = txt.charCodeAt(i);
            // Uppercase
            if (code >= 65 && code <= 90) {
              result += String.fromCharCode(((code - 65 + shift + 26) % 26) + 65);
            }
            // Lowercase
            else if (code >= 97 && code <= 122) {
              result += String.fromCharCode(((code - 97 + shift + 26) % 26) + 97);
            }
          } else {
            result += char;
          }
        }
        caesarOutput.textContent = `Result: ${result}`;
        caesarOutput.className = "sandbox-output success-val";
      });
    }
    else if (challenge.id === 5) {
      // Challenge 5: SQLi
      const wrapper = document.createElement('div');
      wrapper.className = 'sandbox-inner sqli-sandbox';
      wrapper.innerHTML = `
        <div class="interactive-prompt">
          <span>CONSOLE: Live Insecure Login Panel</span>
        </div>
        <div class="sqli-panel">
          <div class="form-row">
            <div class="form-field">
              <label>USERNAME:</label>
              <input type="text" id="sqli-user" placeholder="admin" class="sandbox-input" />
            </div>
            <div class="form-field">
              <label>PASSWORD:</label>
              <input type="password" id="sqli-pass" placeholder="••••••••" class="sandbox-input" />
            </div>
          </div>
          <button id="sqli-btn" class="btn-sandbox" style="margin-top: 1rem; width: 100%;">QUERY DATABASE</button>
          
          <div class="sql-query-viewer">
            <span class="label">COMPILED SQL QUERY:</span>
            <code id="sql-query-display">SELECT * FROM users WHERE username = '' AND password = ''</code>
          </div>
          
          <div id="sqli-output" class="sandbox-output">Console ready. Submit query.</div>
        </div>
      `;
      sandboxContainer.appendChild(wrapper);

      const sqliUser = wrapper.querySelector('#sqli-user') as HTMLInputElement;
      const sqliPass = wrapper.querySelector('#sqli-pass') as HTMLInputElement;
      const sqliBtn = wrapper.querySelector('#sqli-btn') as HTMLButtonElement;
      const queryDisplay = wrapper.querySelector('#sql-query-display') as HTMLElement;
      const sqliOutput = wrapper.querySelector('#sqli-output') as HTMLElement;

      const updateQueryText = () => {
        const u = sqliUser.value.replace(/'/g, "\\'");
        const p = sqliPass.value.replace(/'/g, "\\'");
        queryDisplay.innerHTML = `SELECT * FROM users WHERE username = '<span class="sql-inject">${sqliUser.value}</span>' AND password = '<span class="sql-inject">${sqliPass.value}</span>'`;
      };

      sqliUser.addEventListener('input', updateQueryText);
      sqliPass.addEventListener('input', updateQueryText);

      sqliBtn.addEventListener('click', () => {
        const u = sqliUser.value.trim();
        
        // Simple mock injection checker
        // Patterns to match: ' OR '1'='1 or admin' -- or ' or 1=1
        const hasInjection = /'.*(or|\|\|).*(=|like).*'.*/gi.test(u) || 
                             /'.*(or|\|\|).*[0-9]+=[0-9]+/gi.test(u) || 
                             /admin'\s*--/gi.test(u) ||
                             /'\s*or\s*true\s*--/gi.test(u);

        if (hasInjection) {
          sqliOutput.innerHTML = `
            <span class="success-val">AUTHENTICATION BYPASSED!</span><br/>
            <span>Role: Administrator (admin)</span><br/>
            <span style="color:var(--accent-green);font-weight:bold;">FLAG: FLAG{sqli_bypass_50pts_winner}</span>
          `;
          sqliOutput.className = "sandbox-output success-val";
          addLog('[SUCCESS] SQL injection detected. Authentication bypassed.', 'success');
        } else {
          sqliOutput.innerHTML = `<span class="error-val">SQL EXECUTION ERROR: Invalid username/password. Query returned 0 rows.</span>`;
          sqliOutput.className = "sandbox-output error-val";
        }
      });
    }
  }

  // Handle Flag Submissions
  flagForm.addEventListener('submit', (e) => {
    e.preventDefault();
    if (selectedChallengeId === null) return;

    const challenge = challenges.find(c => c.id === selectedChallengeId);
    if (!challenge) return;

    const submittedFlag = flagInput.value.trim();
    
    if (submittedFlag === challenge.flag) {
      challenge.solved = true;
      playerScore += challenge.points;
      
      // Update local storage
      localStorage.setItem('ctf_score', playerScore.toString());
      const solvedIds = challenges.filter(c => c.solved).map(c => c.id);
      localStorage.setItem('ctf_solved_ids', JSON.stringify(solvedIds));

      flagFeedback.style.display = 'block';
      flagFeedback.className = 'flag-feedback success-text';
      flagFeedback.textContent = `✔ Correct! Node secured (+${challenge.points} pts)`;
      
      addLog(`[SECURED] Solved "${challenge.title}" (+${challenge.points} pts)`, 'success');

      // Update layout
      renderChallengesList();
      updateProgress();
      updateLeaderboard();
      
      // Check if all are solved
      const allSolved = challenges.every(c => c.solved);
      if (allSolved) {
        clearInterval(timerInterval);
        addLog(`[COMPLETE] Congratulations! You secured all challenge nodes in ${playerTime}s!`, 'success');
      }

      // Refresh challenge panel details
      selectChallenge(challenge.id);
    } else {
      flagFeedback.style.display = 'block';
      flagFeedback.className = 'flag-feedback error-text';
      flagFeedback.textContent = '❌ Incorrect flag hash. Try again.';
      addLog(`[ATTEMPT] Failed flag submission for "${challenge.title}"`, 'warning');
    }
  });

  // Leaderboard Sorting & UI updates
  function updateLeaderboard() {
    // Check if player is in hackers array, if so, update their score & time
    let playerHacker = hackers.find(h => h.isPlayer);
    if (!playerHacker) {
      playerHacker = {
        name: nickname,
        points: playerScore,
        time: playerTime,
        isPlayer: true,
        solvedCount: challenges.filter(c => c.solved).length
      };
      hackers.push(playerHacker);
    } else {
      playerHacker.name = nickname;
      playerHacker.points = playerScore;
      playerHacker.time = playerTime;
      playerHacker.solvedCount = challenges.filter(c => c.solved).length;
    }

    // Sort: 1) Points (descending), 2) Time (ascending)
    // Players with 0 points are sorted to bottom.
    hackers.sort((a, b) => {
      if (b.points !== a.points) {
        return b.points - a.points;
      }
      return a.time - b.time;
    });

    // Render ranks
    leaderboardRows.innerHTML = '';
    hackers.forEach((hacker, idx) => {
      const row = document.createElement('div');
      row.className = `leaderboard-row ${hacker.isPlayer ? 'player-row' : ''}`;
      
      const mins = Math.floor(hacker.time / 60).toString().padStart(2, '0');
      const secs = (hacker.time % 60).toString().padStart(2, '0');
      const formattedTime = hacker.points > 0 ? `${mins}:${secs}` : '--:--';
      
      row.innerHTML = `
        <div class="hacker-rank">#${idx + 1}</div>
        <div class="hacker-name">${hacker.name} ${hacker.isPlayer ? '<span class="you-badge">YOU</span>' : ''}</div>
        <div class="hacker-time">${formattedTime}</div>
        <div class="hacker-pts">${hacker.points} pts</div>
      `;
      leaderboardRows.appendChild(row);
    });
  }

  // Simulated live updating bots
  function startBotSimulations() {
    // Every 45 seconds, a random bot will solve a challenge
    const interval = setInterval(() => {
      // Only run if user is active
      if (!nickname) {
        clearInterval(interval);
        return;
      }

      // Filter out bots that haven't solved everything
      const activeBots = hackers.filter(h => !h.isPlayer && h.solvedCount < challenges.length);
      if (activeBots.length === 0) return;

      // Choose a random bot
      const bot = activeBots[Math.floor(Math.random() * activeBots.length)];
      
      // Determine what challenge the bot solves next
      const nextChallengeIdx = bot.solvedCount;
      if (nextChallengeIdx < challenges.length) {
        const solvedChallenge = challenges[nextChallengeIdx];
        
        bot.solvedCount++;
        bot.points += solvedChallenge.points;
        bot.time += Math.floor(Math.random() * 45) + 30; // Add time

        addLog(`[LIVE BROADCAST] Operator "${bot.name}" solved "${solvedChallenge.title}" (+${solvedChallenge.points} pts)`, 'alert');
        updateLeaderboard();
      }
    }, 45000);
  }

  // Init on load
  init();
</script>

