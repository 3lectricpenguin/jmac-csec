---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "Black Penguin IT Security provides high-performance web engineering and enterprise-grade penetration testing to protect your digital assets and accelerate your growth.",
	image = "/favicon.svg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		
		<!-- Primary Meta Tags -->
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="robots" content="index, follow" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url.origin)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url.origin)} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Google Fonts for High-End Cyber Aesthetics -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Orbitron:wght@500;700;800;900&display=swap" rel="stylesheet">

		<!-- Schema.org JSON-LD Structured Data for Local Business SEO -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "ProfessionalService",
				"name": "Black Penguin IT Security",
				"description": "Enterprise-grade penetration testing and high-performance web engineering services.",
				"url": "https://blackpenguin-itsec.com",
				"logo": "https://blackpenguin-itsec.com/favicon.svg",
				"image": "https://blackpenguin-itsec.com/favicon.svg",
				"address": {
					"@type": "PostalAddress",
					"addressRegion": "Michigan, Ohio, Indiana",
					"addressCountry": "US"
				},
				"geo": {
					"@type": "GeoCircle",
					"geoMidpoint": {
						"@type": "GeoCoordinates",
						"latitude": "42.3314",
						"longitude": "-83.0458"
					},
					"radius": "500000"
				},
				"priceRange": "$$$"
			}
		</script>
		
		<style is:global>
			:root {
				--bg-primary: #0a0b10;
				--bg-secondary: #11131c;
				--bg-tertiary: #181c28;
				--accent-green: #a3e635; /* Lime green matching the logo core */
				--accent-green-rgb: 163, 230, 53;
				
				--text-primary: #f8fafc;
				--text-secondary: #94a3b8;
				--text-muted: #64748b;
				
				--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
				--font-display: 'Orbitron', var(--font-sans);
			}

			* {
				box-sizing: border-box;
				padding: 0;
				margin: 0;
			}

			html {
				font-family: var(--font-sans);
				background-color: var(--bg-primary);
				color: var(--text-primary);
				scroll-behavior: smooth;
			}

			body {
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				overflow-x: hidden;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			/* Global Selection Style */
			::selection {
				background-color: rgba(163, 230, 53, 0.25);
				color: #fff;
			}

			/* Global Scrollbar */
			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: var(--bg-primary);
			}
			::-webkit-scrollbar-thumb {
				background: rgba(163, 230, 53, 0.25);
				border-radius: 4px;
				border: 2px solid var(--bg-primary);
			}
			::-webkit-scrollbar-thumb:hover {
				background: var(--accent-green);
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="flex: 1;">
			<slot />
		</main>
		<Footer />
	</body>
</html>