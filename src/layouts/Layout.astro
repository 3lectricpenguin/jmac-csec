---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "JCM IT Solutions provides high-performance web engineering and enterprise-grade penetration testing to protect your assets and accelerate your growth." } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		
		<!-- Google Fonts for High-End Cyber Aesthetics -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Orbitron:wght@500;700;800;900&display=swap" rel="stylesheet">
		
		<style is:global>
			:root {
				--bg-primary: #0a0b10;
				--bg-secondary: #11131c;
				--bg-tertiary: #181c28;
				--accent-green: #a3e635; /* Lime green matching the logo core */
				--accent-green-rgb: 163, 230, 53;
				
				--text-primary: #f8fafc;
				--text-secondary: #94a3b8;
				--text-muted: #64748b;
				
				--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
				--font-display: 'Orbitron', var(--font-sans);
			}

			* {
				box-sizing: border-box;
				padding: 0;
				margin: 0;
			}

			html {
				font-family: var(--font-sans);
				background-color: var(--bg-primary);
				color: var(--text-primary);
				scroll-behavior: smooth;
			}

			body {
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				overflow-x: hidden;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			/* Global Selection Style */
			::selection {
				background-color: rgba(163, 230, 53, 0.25);
				color: #fff;
			}

			/* Global Scrollbar */
			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: var(--bg-primary);
			}
			::-webkit-scrollbar-thumb {
				background: rgba(163, 230, 53, 0.25);
				border-radius: 4px;
				border: 2px solid var(--bg-primary);
			}
			::-webkit-scrollbar-thumb:hover {
				background: var(--accent-green);
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="flex: 1;">
			<slot />
		</main>
		<Footer />
	</body>
</html>